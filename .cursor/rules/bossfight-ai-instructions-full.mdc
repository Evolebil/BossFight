```cpp
class Boss {
private:
    float x, y;
    float hp, maxHP;
    BossState currentState;
    float attackTimer;
    
    static constexpr float ATTACK_COOLDOWN = 3.0f;
    
public:
    explicit Boss(float spawnX, float spawnY) 
        : x(spawnX), y(spawnY), 
          hp(1000), maxHP(1000),
          currentState(BossState::IDLE),
          attackTimer(0.0f) {}
    
    void update(float deltaTime) {
        // Обновление таймера
        attackTimer += deltaTime;
        
        // Проверка смерти
        if (hp <= 0) {
            currentState = BossState::DEATH;
            return;
        }
        
        // Логика атаки
        if (attackTimer >= ATTACK_COOLDOWN) {
            performAttack();
            attackTimer = 0.0f;
        }
    }
    
    [[nodiscard]] bool isAlive() const {
        return hp > 0;
    }
    
    void takeDamage(float damage) {
        hp -= damage;
        if (hp < 0) hp = 0;
    }
    
private:
    void performAttack() {
        // Логика атаки
    }
};
```

ПОЧЕМУ ЭТО ПРАВИЛЬНО:
1. Smart pointer не нужен (stack allocation)
2. constexpr для константы
3. Инициализация через список (быстрее)
4. [[nodiscard]] для isAlive
5. const для методов не меняющих состояние
6. Приватные методы в конце
7. Понятные комментарии к блокам

