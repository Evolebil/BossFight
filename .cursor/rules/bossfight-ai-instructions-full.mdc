struct AABB {
    float x, y, width, height;
    
    bool intersects(const AABB& other) const {
        return x < other.x + other.width &&
               x + width > other.x &&
               y < other.y + other.height &&
               y + height > other.y;
    }
};

class Player {
    AABB getHitbox() const {
        return {x - width/2, y - height/2, width, height};
    }
};
