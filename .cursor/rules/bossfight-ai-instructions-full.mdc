void checkCollisions() {
    // ШАГ 1: Получаем хитбокс игрока
    AABB playerBox = getHitbox();
    
    // ШАГ 2: Вычисляем какие тайлы проверять
    // Формула: pixelX / tileSize = номер тайла
    int startX = (int)(x - width/2) / TILE_SIZE;
    int endX = (int)(x + width/2) / TILE_SIZE;
    int startY = (int)(y - height/2) / TILE_SIZE;
    int endY = (int)(y + height/2) / TILE_SIZE;
    
    // ШАГ 3: Проверяем каждый тайл в области
    for (int ty = startY; ty <= endY; ty++) {
        for (int tx = startX; tx <= endX; tx++) {
            TileType tile = getTileAt(tx, ty);
            
            // ШАГ 4: Если тайл твёрдый - разрешаем коллизию
            if (isSolid(tile)) {
                resolveCollision(playerBox, getTileBox(tx, ty));
            }
        }
    }
}
```

